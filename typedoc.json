{
  "entryPoints": ["src"],
  "entryPointStrategy": "expand",
  "out": "docs",
  "exclude": [
    "**/node_modules/**",
    "**/lib/**",
    "**/dist/**",
    "**/*.spec.ts",
    "**/*.test.ts"
  ],
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "intentionallyNotExported": [
    "ColorLike",
    "ComponentLike",
    "ControllerCommandHandler",
    "ElementResourceManager",
    "EmbeddedModel",
    "ResourceManagerLike",
    "ResourceModelLike",
    "ResourceOwner",
    "SourceModelResourceLike",
    "Surface",
    "SurfaceAnimationLayer",
    "SurfaceRadioStrip",
    "ViewControllerLike"
  ],
  "skipErrorChecking": false
}