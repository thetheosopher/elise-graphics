{
    "name": "elise-graphics",
    "version": "1.1.0",
    "description": "\"Elise Graphics Library\"",
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "module": "lib-esm/index.js",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "import": "./lib-esm/index.js",
            "require": "./lib/index.js",
            "default": "./lib/index.js"
        },
        "./lib/*": {
            "types": "./lib/*.d.ts",
            "import": "./lib-esm/*.js",
            "require": "./lib/*.js",
            "default": "./lib/*.js"
        },
        "./lib-esm/*": {
            "types": "./lib/*.d.ts",
            "import": "./lib-esm/*.js"
        }
    },
    "scripts": {
        "clean": "shx rm -rf _bundles lib lib-esm",
        "doc": "npx typedoc",
        "test": "jest",
        "build": "npm run clean && tsc && tsc -m es6 --outDir lib-esm && webpack",
        "format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\"",
        "lint": "eslint src/",
        "prepare": "npm run build",
        "prepublishOnly": "npm run lint",
        "preversion": "npm run lint",
        "version": "npm run format && git add -A src",
        "postversion": "git push && git push --tags"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/thetheosopher/elise-graphics.git"
    },
    "keywords": [
        "canvas",
        "graphics",
        "2d"
    ],
    "author": "Michael A. McCloskey",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/thetheosopher/elise-graphics/issues"
    },
    "homepage": "https://github.com/thetheosopher/elise-graphics#readme",
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/jest": "^30.0.0",
        "@typescript-eslint/eslint-plugin": "^8.57.0",
        "@typescript-eslint/parser": "^8.57.0",
        "eslint": "^10.0.3",
        "eslint-config-prettier": "^10.1.8",
        "jest": "^30.3.0",
        "prettier": "^3.8.1",
        "shx": "^0.4.0",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "typedoc": "^0.28.17",
        "typescript": "^5.9.3",
        "webpack": "^5.105.4",
        "webpack-cli": "^7.0.0"
    },
    "files": [
        "lib/**/*",
        "lib-esm/**/*",
        "_bundles/**/*"
    ]
}
