{
    "compilerOptions": {
      "target": "es2020",
      "module": "commonjs",
      "lib": [ "es2020", "dom" ],
      "sourceMap": true,
      "declaration": true,
      "outDir": "./lib",
      "strict": true,
      "moduleResolution": "node",
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "**/__tests__/*"]
  }
